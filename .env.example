## Infinite Socrates environment variables (example)
#
# Copy this file to `.env` and fill in values.
# Never commit `.env`.

# OpenAI
OPENAI_API_KEY=

# Firebase / Firestore
# Option A: service account file path (recommended for local dev)
GOOGLE_APPLICATION_CREDENTIALS=

# Option B: explicit project id (optional, depends on how Firebase is initialized)
FIREBASE_PROJECT_ID=

